rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: posts
    // Fields:
    //   - title: string (required)
    //   - content: string (required)
    //   - category: string (required)
    //   - createdAt: timestamp (required)
    //   - authorUid: string (required)
    //
    // Collection: users
    // Fields:
    //   - email: string (required)
    //   - role: string (required, 'admin' or 'user')
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email.lower() == "orelynd@gmail.com" && 
        request.auth.token.email_verified == true
      );
    }

    function isValidPost(data) {
      return data.keys().hasAll(['title', 'content', 'category', 'createdAt', 'authorUid']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.content is string && data.content.size() > 0 && data.content.size() < 50000 &&
             data.category is string && data.category.size() > 0 &&
             data.createdAt is timestamp &&
             data.authorUid == request.auth.uid;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /posts/{postId} {
      allow read: if true; // Publicly readable
      allow create: if isAdmin() && isValidPost(request.resource.data);
      allow update: if isAdmin() && isValidPost(request.resource.data) && 
                      request.resource.data.authorUid == resource.data.authorUid;
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create, update: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
